import numpy as np

def simulate_growth(temp, pH, oxygen, stir):
    t = np.linspace(0, 24, 100)

    # Base growth rate
    r = 0.5

    # Environmental effects
    if temp < 30 or temp > 40:
        r *= 0.6

    if pH < 6 or pH > 8:
        r *= 0.7

    if oxygen < 30:
        r *= 0.5

    if stir < 100:
        r *= 0.8

    K = 100  # carrying capacity
    N0 = 5

    biomass = K / (1 + ((K - N0) / N0) * np.exp(-r * t))

    return t, biomass